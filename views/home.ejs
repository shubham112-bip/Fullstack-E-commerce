<!DOCTYPE html>
<html>
<head>
  <title>ShopKart - Home</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <script defer src="/js/cart.js"></script>
</head>
<body>
  <%- include("partials/header", { user: true }) %>
  <div class="container mt-5">
    <h2>All Products</h2>
    <div class="row">
      <% clothingProducts.forEach(p => { %>
        <div class="col-md-4">
          <div class="card mb-4">
            <img src="<%= p.images[0] || 'https://via.placeholder.com/200' %>" class="card-img-top">
            <div class="card-body">
              <h5 class="card-title"><%= p.name %></h5>
              <p class="card-text">₹<%= p.price %></p>
              <a href="/products/<%= p._id %>" class="btn btn-primary">View</a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
  <%- include("partials/footer") %>
</body>
</html>
