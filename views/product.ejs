<!DOCTYPE html>
<html>
<head>
  <title><%= product.name %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <script defer src="/js/cart.js"></script>
</head>
<body>
  <%- include("partials/header", { user: true }) %>
  <div class="container mt-5">
    <div class="row">
      <div class="col-md-6">
        <img src="<%= product.images[0] || 'https://via.placeholder.com/300' %>" class="img-fluid">
      </div>
      <div class="col-md-6">
        <h3><%= product.name %></h3>
        <p><%= product.description %></p>
        <p><strong>₹<%= product.price %></strong></p>

        <select id="size" class="form-select mb-2">
          <% product.sizes.forEach(s => { %>
            <option value="<%= s %>"><%= s %></option>
          <% }) %>
        </select>

        <select id="color" class="form-select mb-2">
          <% product.colors.forEach(c => { %>
            <option value="<%= c %>"><%= c %></option>
          <% }) %>
        </select>

        <button class="btn btn-success add-to-cart" data-product='<%- JSON.stringify({
          product_id: product._id,
          name: product.name,
          price: product.price,
          selectedSize: "",
          selectedColor: ""
        }) %>'
        onclick="this.dataset.product = JSON.stringify({...JSON.parse(this.dataset.product), selectedSize: document.getElementById('size').value, selectedColor: document.getElementById('color').value})">
          Add to Cart
        </button>
      </div>
    </div>
  </div>
  <%- include("partials/footer") %>
</body>
</html>